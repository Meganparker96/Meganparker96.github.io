<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sweet Pea Archives</title>
<style>
  :root {
    --cream: #FAF6EE;
    --ink: #2E2A22;
    --brown-light: #5A5240;
    --rust: #A6673E;
    --dark: #3D3626;
    --tan1: #D8C3A0;
    --tan2: #C9B29C;
    --tan3: #D9B8A8;
    --sage: #B6C6BC;
    --border: #D8CBB0;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--cream);
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
  }
  .sans {
    font-family: Arial, Helvetica, sans-serif;
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 64px;
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 246, 238, 0.92);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--border);
  }
  header .logo {
    font-size: 20px;
    letter-spacing: 0.5px;
  }
  [id] {
    scroll-margin-top: 100px;
  }
  nav {
    display: flex;
    gap: 36px;
    font-size: 13px;
    color: var(--brown-light);
  }
  nav a {
    color: inherit;
    text-decoration: none;
  }
  nav a:hover {
    text-decoration: underline;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    align-items: stretch;
    min-height: 74vh;
  }
  .hero-text {
    padding: 80px 56px 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 620px;
    margin-left: auto;
  }
  .eyebrow {
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--rust);
    margin: 0 0 20px;
  }
  h1 {
    font-size: clamp(42px, 5.5vw, 68px);
    font-weight: 400;
    line-height: 1.12;
    margin: 0 0 26px;
  }
  .hero-text p.lead {
    font-size: 16px;
    line-height: 1.8;
    color: var(--brown-light);
    margin: 0 0 36px;
    max-width: 440px;
  }
  .btn-row {
    display: flex;
    gap: 14px;
  }
  .btn {
    font-family: Arial, sans-serif;
    padding: 13px 26px;
    border-radius: 4px;
    font-size: 14px;
    cursor: pointer;
    border: 1px solid var(--ink);
  }
  .btn-primary {
    background: var(--ink);
    color: var(--cream);
  }
  .btn-secondary {
    background: transparent;
    color: var(--ink);
  }
  .photo-placeholder {
    background: var(--tan1);
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8B6F47;
    text-align: center;
    font-family: Arial, sans-serif;
  }
  .photo-placeholder .cap {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 8px;
  }

  section.gallery {
    padding: 110px 64px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .section-label {
    font-family: Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--rust);
    text-align: center;
    margin: 0 0 44px;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
  }
  .gallery-grid div {
    aspect-ratio: 3/4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: Arial, sans-serif;
    color: #6B4F2C;
  }

  .quote-section {
    background: var(--dark);
    color: var(--cream);
    padding: 100px 64px;
    text-align: center;
  }
  .quote-section p.quote {
    font-size: 27px;
    font-style: italic;
    line-height: 1.65;
    max-width: 580px;
    margin: 0 auto 20px;
  }
  .quote-section p.attr {
    font-family: Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #B5A88C;
    margin: 0;
  }

  .paths {
    padding: 110px 64px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .paths-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
  }
  .path-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .path-card .cover {
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .path-card .body {
    padding: 22px;
  }
  .path-card h3 {
    font-size: 17px;
    font-weight: 400;
    margin: 0 0 8px;
  }
  .path-card p {
    font-family: Arial, sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: var(--brown-light);
    margin: 0;
  }

  .pricing {
    padding: 110px 64px;
    max-width: 900px;
    margin: 0 auto;
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 36px;
  }
  .price-card {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 36px 32px;
    background: #fff;
  }
  .price-card.featured {
    border: 2px solid var(--rust);
  }
  .price-card .price-tag {
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--rust);
    margin: 0 0 6px;
  }
  .price-card h3 {
    font-size: 19px;
    font-weight: 400;
    margin: 0 0 14px;
  }
  .price-card ul {
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
    font-size: 13px;
    line-height: 2;
    color: var(--brown-light);
  }
  .price-card ul li::before {
    content: "\2022";
    color: var(--rust);
    margin-right: 8px;
  }

  footer.cta {
    background: var(--ink);
    color: var(--cream);
    padding: 100px 64px;
    text-align: center;
  }
  footer.cta p {
    font-size: 30px;
    font-weight: 400;
    line-height: 1.4;
    max-width: 520px;
    margin: 0 auto 32px;
  }
  footer.cta .btn-primary {
    background: var(--rust);
    border: none;
  }

  .contact {
    padding: 100px 64px;
    max-width: 760px;
    margin: 0 auto;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
  }
  .contact-details p {
    font-family: Arial, sans-serif;
    font-size: 14px;
    line-height: 2;
    color: var(--brown-light);
    margin: 0;
  }
  .contact-details a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rust);
  }
  .contact-form input, .contact-form textarea {
    width: 100%;
    font-family: Arial, sans-serif;
    font-size: 14px;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 14px;
    background: #fff;
    color: var(--ink);
  }
  .contact-form textarea {
    min-height: 100px;
    resize: vertical;
  }
  .site-footer {
    text-align: center;
    padding: 28px 64px;
    font-family: Arial, sans-serif;
    font-size: 12px;
    color: var(--brown-light);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 720px) {
    .hero { grid-template-columns: 1fr; min-height: unset; }
    .hero-text { padding: 48px 28px; margin-left: 0; }
    .photo-placeholder { min-height: 300px; }
    section.gallery, .paths, .pricing, .contact, .quote-section, footer.cta { padding-left: 28px; padding-right: 28px; padding-top: 64px; padding-bottom: 64px; }
    .gallery-grid, .paths-grid, .pricing-grid, .contact-grid { grid-template-columns: 1fr; }
    nav { display: none; }
    header { padding: 16px 24px; }
  }
</style>
</head>
<body>

  <header>
    <div class="logo" style="display:flex; align-items:center; gap:14px;">
      <div style="width:48px; height:48px; border-radius:50%; background:#F0DCC8; border:1.5px dashed var(--rust); flex-shrink:0;" title="Logo placeholder"></div>
      Sweet Pea Archives
    </div>
    <nav>
      <a href="#archive">The archive</a>
      <a href="#paths">Two ways in</a>
      <a href="#pricing">Pricing</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-text" style="position:relative;">
      <p class="eyebrow">Not a memorial. An archive of a life</p>
      <h1>Sit down.<br>Tell us everything.</h1>
      <p class="lead">We bring the cameras to your kitchen table. You bring the stories &mdash; the ordinary Tuesdays, the opinions on everything, the bits people forget to ask about before it's too late.</p>
      <div class="btn-row">
        <a href="#contact" class="btn btn-primary" style="text-decoration:none; display:inline-block;">Book a conversation</a>
        <a href="#paths" class="btn btn-secondary" style="text-decoration:none; display:inline-block;">How it works</a>
      </div>
    </div>
    <div class="photo-placeholder">
      <div>
        <div style="font-size:34px;">&#128247;</div>
        <p class="cap">Replace with: hands around a teacup</p>
      </div>
    </div>
  </section>

  <section class="gallery" id="archive">
    <h2 style="text-align:center; font-size:28px; font-weight:400; margin:0 0 8px;">The archive</h2>
    <p class="section-label">What it actually looks like</p>
    <div class="gallery-grid">
      <div style="background: var(--tan2);">Photo: tea &amp; hands</div>
      <div style="background: var(--sage);">Photo: mid-interview</div>
      <div style="background: var(--tan3);">Photo: camera setup</div>
    </div>
  </section>

  <section class="quote-section">
    <svg width="70" height="24" viewBox="0 0 70 24" style="margin-bottom: 18px;">
      <path d="M35,12 L0,12 M70,12 L35,12" stroke="#B5A88C" stroke-width="1"/>
      <path d="M35,4 C41,7 42,17 35,20 C28,17 29,7 35,4 Z" fill="#B6C6BC" opacity="0.8"/>
    </svg>
    <p class="quote">"I wish I'd asked my nan what an ordinary Tuesday felt like to her. That's the bit we lose first."</p>
    <p class="attr">Why we started this</p>
  </section>

  <section class="paths" id="paths">
    <p class="section-label">Two ways in</p>
    <div class="paths-grid">
      <div class="path-card">
        <div class="cover" style="background: var(--tan1);">Photo: person, portrait</div>
        <div class="body">
          <p class="sans" style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--rust); margin:0 0 8px;">For yourself</p>
          <h3>Your own archive</h3>
          <p>Tell your own story, in your own time, for the people who'll want it one day.</p>
        </div>
      </div>
      <div class="path-card">
        <div class="cover" style="background: var(--tan2);">Photo: gift moment</div>
        <div class="body">
          <p class="sans" style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--rust); margin:0 0 8px;">For someone you love</p>
          <h3>A gift for someone else</h3>
          <p>Give a parent or grandparent a proper excuse to talk about themselves for once.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing" id="pricing">
    <p class="section-label">Pricing</p>
    <h2 style="text-align:center; font-size:28px; font-weight:400; margin:0 0 10px;">One package, add what you need</h2>
    <p class="sans" style="text-align:center; font-size:14px; color:var(--brown-light); max-width:460px; margin:0 auto 40px;">No bronze, silver, gold nonsense &mdash; just one honest package with a few thoughtful extras.</p>
    <div class="pricing-grid">
      <div class="price-card featured">
        <p class="sans price-tag">From &pound;295</p>
        <h3>The archive session</h3>
        <ul class="sans">
          <li>Up to 2 hours on site</li>
          <li>Guided interview, no script</li>
          <li>Fully edited 15&ndash;20 min film</li>
          <li>Digital delivery, private link</li>
        </ul>
        <a href="#contact" class="btn btn-primary" style="width:100%; margin-top:8px; text-decoration:none; display:block; text-align:center; box-sizing:border-box;">Book this</a>
      </div>
      <div class="price-card">
        <p class="sans price-tag">Add-ons</p>
        <h3>Make it a keepsake</h3>
        <ul class="sans">
          <li>+&pound;35 &mdash; engraved USB drive</li>
          <li>+&pound;55 &mdash; printed photo album</li>
          <li>+&pound;40 &mdash; extra hour of interview</li>
          <li>+&pound;25 &mdash; extra edited copy for family</li>
        </ul>
      </div>
    </div>
  </section>

  <footer class="cta" id="start">
    <p>One afternoon. One conversation. A voice that doesn't fade.</p>
    <a href="#contact" class="btn btn-primary" style="text-decoration:none; display:inline-block;">Start your archive</a>
  </footer>

  <section class="contact" id="contact">
    <p class="section-label">Get in touch</p>
    <h2 style="text-align:center; font-size:26px; font-weight:400; margin:0 0 34px;">Let's talk it through</h2>
    <div class="contact-grid">
      <div class="contact-details">
        <p><strong>Email</strong><br><a href="mailto:hello@sweetpeaarchives.com">hello@sweetpeaarchives.com</a></p>
        <p style="margin-top:16px;"><strong>Phone</strong><br>07000 000 000</p>
        <p style="margin-top:16px;"><strong>Based in</strong><br>Oxford, and happy to travel</p>
      </div>
      <form class="contact-form">
        <input type="text" name="name" placeholder="Your name" required>
        <input type="email" name="email" placeholder="Your email" required>
        <input type="tel" name="phone" placeholder="Mobile number (optional)">
        <textarea name="message" placeholder="Tell us a little about who you'd like to interview" required></textarea>
        <label class="sans" style="display:flex; align-items:flex-start; gap:10px; font-size:12.5px; line-height:1.6; color:var(--brown-light); margin-bottom:16px; cursor:pointer;">
          <input type="checkbox" name="consent" required style="width:auto; margin:3px 0 0;">
          <span>I'm happy for Sweet Pea Archives to store the details I've provided and use them to respond to my enquiry. We'll never share your details or use them for anything else.</span>
        </label>
        <button type="submit" class="btn btn-primary" style="width:100%;">Send message</button>
      </form>
    </div>
  </section>

  <div class="site-footer">&copy; Sweet Pea Archives</div>

</body>
</html>
